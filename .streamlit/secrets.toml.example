# Streamlit Secrets Configuration (Example)
# This file shows the format for secrets.toml used by Streamlit Community Cloud.
# DO NOT commit your real secrets.toml to GitHub.
#
# To deploy:
# 1. Go to https://share.streamlit.io/
# 2. Create new app pointing to your GitHub repo
# 3. In App Settings → Secrets, paste your actual secrets in TOML format
# 4. Copy the contents below and replace placeholder values

# Groq API Key for LLM calls (get free key from console.groq.com)
GROQ_API_KEY = "gsk_your_actual_api_key_here"

# Secret key for JWT token signing (generate a secure random string)
SECRET_KEY = "your-secure-random-secret-key-here-change-this"

# Database URL (SQLite works on Streamlit Cloud with file persistence)
DATABASE_URL = "sqlite:///./productivity.db"

# Checkpoint database for LangGraph agent state
CHECKPOINT_DB = "agent_state.db"

# Token expiry in minutes (1440 = 24 hours)
TOKEN_EXPIRE_MINUTES = 1440

# Backend API endpoint (when running backend separately, or localhost for testing)
# BACKEND_URL = "http://localhost:8001"  # Use if backend runs on different port/host

# Optional: Demo mode (show demo credentials on login page)
DEMO_MODE = "false"
DEMO_SEED = "false"
